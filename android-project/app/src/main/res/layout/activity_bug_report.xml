<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Aviso quando e-mail não configurado -->
        <TextView
            android:id="@+id/tvNoEmailWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bug_no_email_configured"
            android:textSize="14sp"
            android:textColor="@color/warning"
            android:background="@color/warning_surface"
            android:padding="16dp"
            android:visibility="gone" />

        <!-- Formulário -->
        <LinearLayout
            android:id="@+id/layoutBugForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bug_report_desc_label"
                android:textSize="13sp"
                android:textColor="@color/on_surface_variant"
                android:layout_marginBottom="16dp" />

            <!-- Título -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/bug_title_hint"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBugTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:maxLength="120"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Descrição -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/bug_description_hint"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBugDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="5"
                    android:maxLines="10"
                    android:gravity="top"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Anexos -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bug_attachments_label"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAttachments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddAttachment"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="@string/bug_add_attachment"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="10dp"
                android:layout_marginBottom="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendBugReport"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/bug_send"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                app:cornerRadius="14dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>

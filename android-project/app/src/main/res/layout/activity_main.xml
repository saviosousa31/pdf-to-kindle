<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ═══ HEADER ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/primary"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="EPUB Maker"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.02" />

                <!-- Fix item 2: botão de engrenagem com ícone centralizado -->
                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_settings_gear"
                    android:background="@drawable/btn_settings_bg"
                    android:contentDescription="Configurações"
                    android:padding="10dp"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Converta PDFs em livros digitais"
                android:textSize="13sp"
                android:textColor="#CCE8FF"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <!-- ═══ BODY ════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <!-- Status chip -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecione um arquivo PDF para começar."
                android:textSize="13sp"
                android:textColor="@color/on_surface_variant"
                android:background="@color/surface_variant"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="14dp" />

            <!-- ─── Card: Arquivo PDF ─────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPdf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Arquivo PDF"
                            android:textSize="16sp" android:fontFamily="sans-serif-medium"
                            android:textStyle="bold" android:textColor="@color/on_surface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📄" android:textSize="20sp" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvPdfName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nenhum arquivo selecionado"
                        android:textSize="13sp" android:fontFamily="sans-serif"
                        android:textColor="@color/on_surface_variant"
                        android:ellipsize="middle" android:singleLine="true"
                        android:layout_marginBottom="14dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelect"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:text="Selecionar PDF" android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" app:cornerRadius="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Card: Capa ─────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCover"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardElevation="0dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Capa do Livro"
                            android:textSize="16sp" android:fontFamily="sans-serif-medium"
                            android:textStyle="bold" android:textColor="@color/on_surface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🖼" android:textSize="20sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSearchCover"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:text="Buscar Capa" android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:cornerRadius="12dp" android:layout_marginBottom="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectLocalCover"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:text="🖼  Usar Foto do Celular" android:textSize="14sp"
                        android:fontFamily="sans-serif"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:cornerRadius="12dp" android:layout_marginBottom="4dp" />

                    <!-- Prévia capa local -->
                    <LinearLayout
                        android:id="@+id/layoutLocalCover"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="10dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Capa selecionada do celular:"
                            android:textSize="13sp" android:fontFamily="sans-serif"
                            android:textColor="@color/on_surface_variant"
                            android:layout_marginBottom="8dp" />
                        <FrameLayout android:layout_width="140dp" android:layout_height="210dp">
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardLocalCoverPreview"
                                android:layout_width="match_parent" android:layout_height="match_parent"
                                app:cardCornerRadius="8dp" app:cardElevation="3dp"
                                app:strokeWidth="7dp" app:strokeColor="@color/selected_green">
                                <ImageView android:id="@+id/imgLocalCover"
                                    android:layout_width="match_parent" android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:contentDescription="Capa do celular" />
                            </com.google.android.material.card.MaterialCardView>
                            <FrameLayout android:layout_width="26dp" android:layout_height="26dp"
                                android:layout_gravity="top|end" android:layout_margin="5dp"
                                android:background="@drawable/check_badge_bg" android:elevation="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center" android:text="✓"
                                    android:textSize="13sp" android:textColor="#FFFFFF" android:textStyle="bold" />
                            </FrameLayout>
                        </FrameLayout>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRemoveLocalCover"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="Remover" android:textSize="12sp"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Hint + carrossel -->
                    <TextView android:id="@+id/tvCoverHint"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:fontFamily="sans-serif"
                        android:textColor="@color/on_surface_variant"
                        android:visibility="gone" android:paddingTop="8dp"
                        android:layout_marginBottom="4dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCovers"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:visibility="gone"
                        android:clipToPadding="false"
                        android:paddingHorizontal="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLoadMore"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Carregar mais capas" android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:visibility="gone"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Card: Conversão (sempre visível quando PDF selecionado — item 5) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardConvert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardElevation="0dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Conversão" android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" android:textStyle="bold"
                        android:textColor="@color/on_surface" android:layout_marginBottom="14dp" />
                    <!-- item 5: texto muda dinamicamente por código -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConvert"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:text="Converter para EPUB (Sem capa)"
                        android:textSize="16sp" android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        app:cornerRadius="14dp" android:layout_marginBottom="12dp" />
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressConvert"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:visibility="gone" android:layout_marginBottom="6dp"
                        app:indicatorColor="@color/primary" app:trackColor="@color/surface_variant"
                        app:trackCornerRadius="4dp" />
                    <TextView android:id="@+id/tvProgress"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:fontFamily="sans-serif"
                        android:textColor="@color/on_surface_variant"
                        android:visibility="gone" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Card: Resultado ────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardElevation="0dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/selected_green"
                app:strokeWidth="2dp"
                app:cardBackgroundColor="@color/success_surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <TextView android:id="@+id/tvResult"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="14sp" android:fontFamily="sans-serif-medium"
                        android:textColor="@color/success" android:lineSpacingMultiplier="1.3"
                        android:layout_marginBottom="16dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDownload"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:text="⬇  Baixar EPUB" android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" app:cornerRadius="12dp"
                        android:layout_marginBottom="10dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmail"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:text="Enviar por E-mail" android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:cornerRadius="12dp" android:layout_marginBottom="10dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNew"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:text="Converter Novo Arquivo" android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" app:cornerRadius="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>

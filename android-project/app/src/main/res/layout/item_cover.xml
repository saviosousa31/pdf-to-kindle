<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="140dp"
    android:layout_height="210dp"
    android:layout_marginHorizontal="6dp">

    <!-- Card com borda verde quando selecionado (controlada pelo adapter) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardItem"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="8dp"
        app:cardElevation="3dp"
        app:strokeWidth="0dp"
        app:strokeColor="#2E7D32">

        <ImageView
            android:id="@+id/imgCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Capa do livro" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Badge de check no canto superior direito -->
    <FrameLayout
        android:id="@+id/viewSelected"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_gravity="top|end"
        android:layout_margin="5dp"
        android:background="@drawable/check_badge_bg"
        android:visibility="gone"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="✓"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </FrameLayout>

</FrameLayout>

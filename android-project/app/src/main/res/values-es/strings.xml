    <string name="help_kindle_email_title">Cómo encontrar el correo del Kindle</string>
    <string name="help_kindle_email_desc">En la app de Amazon, accede a tu cuenta y ve a "Administrar Mi Contenido y Dispositivos" → selecciona tu Kindle → el correo aparecerá como "Enviar a Kindle".</string>
    <string name="help_authorize_sender_title">Cómo autorizar el remitente en Kindle</string>
    <string name="help_authorize_sender_desc">En la app de Amazon, ve a "Administrar Mi Contenido y Dispositivos" → pestaña "Preferencias" → "Configuración de Enviar a Kindle" → agrega el correo remitente en "Correos Personales Aprobados".</string>
    <string name="help_apppassword_title">Cómo crear una Contraseña de App de Gmail</string>
    <string name="help_apppassword_desc">Gmail requiere una "Contraseña de App" especial. Sigue los pasos:\n\n1. Ve a myaccount.google.com.\n2. Toca "Seguridad".\n3. Activa "Verificación en 2 pasos".\n4. Busca "Contraseñas de app".\n5. Crea una contraseña para "EPUB Maker".\n6. Usa esa contraseña en el campo Contraseña de App.</string>

    <string name="btn_close">Chiudi</string>
    <string name="help_kindle_email_title">Come trovare l\'email del Kindle</string>
    <string name="help_kindle_email_desc">Nell\'app Amazon, accedi all\'account e vai su "Gestisci Contenuto e Dispositivi" → seleziona il tuo Kindle → l\'email apparirà come "Invia a Kindle".</string>
    <string name="help_authorize_sender_title">Come autorizzare il mittente su Kindle</string>
    <string name="help_authorize_sender_desc">Nell\'app Amazon, vai su "Gestisci Contenuto e Dispositivi" → scheda "Preferenze" → "Impostazioni Invia a Kindle" → aggiungi l\'email mittente in "Email Personali Approvate".</string>
    <string name="help_apppassword_title">Come creare una Password App Gmail</string>
    <string name="help_apppassword_desc">Gmail richiede una "Password App" speciale. Segui i passaggi:\n\n1. Vai su myaccount.google.com.\n2. Tocca "Sicurezza".\n3. Attiva "Verifica in 2 passaggi".\n4. Cerca "Password per le app".\n5. Crea una password per "EPUB Maker".\n6. Usa quella password nel campo Password App.</string>

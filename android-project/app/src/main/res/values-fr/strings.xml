    <string name="btn_close">Fermer</string>
    <string name="help_kindle_email_title">Comment trouver l\'e-mail de votre Kindle</string>
    <string name="help_kindle_email_desc">Dans l\'application Amazon, accédez à "Gérer Mon Contenu et Mes Appareils" → sélectionnez votre Kindle → l\'e-mail apparaît comme "Envoyer vers Kindle".</string>
    <string name="help_authorize_sender_title">Comment autoriser l\'expéditeur sur Kindle</string>
    <string name="help_authorize_sender_desc">Dans l\'application Amazon, allez dans "Gérer Mon Contenu et Mes Appareils" → onglet "Préférences" → "Paramètres d\'envoi vers Kindle" → ajoutez l\'e-mail expéditeur dans "E-mails personnels approuvés".</string>
    <string name="help_apppassword_title">Comment créer un mot de passe d\'application Gmail</string>
    <string name="help_apppassword_desc">Gmail exige un "Mot de passe d\'application" spécial. Suivez les étapes :\n\n1. Allez sur myaccount.google.com.\n2. Appuyez sur "Sécurité".\n3. Activez "Validation en 2 étapes".\n4. Recherchez "Mots de passe des applications".\n5. Créez un mot de passe pour "EPUB Maker".\n6. Utilisez ce mot de passe dans le champ Mot de passe de l\'application.</string>
